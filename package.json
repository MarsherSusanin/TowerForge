{
  "name": "towerforge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "homepage": "https://lindforge.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lindforge-Studios/TowerForge.git"
  },
  "towerforge": {
    "studioName": "Lindforge Studios",
    "telegram": "https://t.me/lindforge"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "studio": "node packages/studio/server.mjs",
    "mcp": "node packages/mcp/server.mjs",
    "validate": "node packages/cli/validate.mjs",
    "sim": "node packages/cli/sim.mjs",
    "balance": "node packages/cli/balance.mjs",
    "build": "node packages/cli/build.mjs",
    "package:web": "node packages/cli/package.mjs --kind web",
    "project:export": "node packages/cli/project-pack.mjs export",
    "project:import": "node packages/cli/project-pack.mjs import",
    "themes:list": "node packages/cli/theme-pack.mjs list",
    "themes:apply": "node packages/cli/theme-pack.mjs apply",
    "maps:compile": "node packages/cli/maps-compile.mjs",
    "migrate": "node packages/cli/migrate.mjs",
    "build:engine": "tsc -p packages/engine/tsconfig.build.json",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p packages/engine/tsconfig.json",
    "data:validate": "node packages/cli/validate.mjs",
    "desktop:dev": "npm --workspace @towerforge/desktop run dev",
    "desktop:build": "npm --workspace @towerforge/desktop run build",
    "desktop:build:mac": "npm --workspace @towerforge/desktop run build -- --bundles dmg",
    "desktop:build:win": "npm --workspace @towerforge/desktop run build -- --bundles nsis,msi",
    "desktop:build:linux": "npm --workspace @towerforge/desktop run build -- --bundles appimage,deb,rpm",
    "brand:build": "node scripts/build-brand-assets.mjs",
    "tiles:build-presets": "node scripts/build-tile-preset-assets.mjs",
    "plugin:build": "node scripts/build-codex-plugin.mjs",
    "plugin:validate": "node scripts/validate-codex-plugin.mjs",
    "plugin:smoke": "node scripts/smoke-codex-plugin.mjs",
    "plugin:export": "node scripts/export-codex-plugin-repository.mjs",
    "brand:icons": "npm --workspace @towerforge/desktop exec tauri icon -- ../../assets/brand/towerforge-app-icon.png"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.214",
    "@anthropic-ai/sdk": "^0.93.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "0.144.6",
    "fast-xml-parser": "^5.10.1",
    "pngjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
